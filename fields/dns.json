{
  "dns": {
    "servers": [
      {
        "type": "tls",
        "tag": "dns_cloudflare",
        "server": "1.1.1.1",
        "detour": "🚀 Default"
      },
      {
        "type": "tls",
        "tag": "dns_google",
        "server": "8.8.8.8",
        "detour": "🚀 Default"
      },
      {
        "type": "udp",
        "tag": "dns_ali",
        "server": "223.5.5.5"
      },
      {
        "type": "local",
        "tag": "dns_local"
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "server": "dns_ali"
      },
      {
        "rule_set": ["geosite-private"],
        "server": "dns_local"
      },
      {
        "action": "evaluate",
        "server": "dns_cloudflare"
      },
      {
        "match_response": true,
        "rule_set": ["geoip-cn"],
        "server": "dns_ali"
      },
      {
        "action": "route",
        "server": "dns_cloudflare"
      }
    ],
    "optimistic": {
      "enabled": true
    },
    "final": "dns_cloudflare"
  }
}
